<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2"/>
  </startup>

  <appSettings>
    <!-- Putanja za cuvanje fajlova sesije na disku -->
    <add key="storagePath"       value="DroneStorage"/>

    <!--
      ZADATAK 1 (e): Pragovi su u konfiguraciji
      Prag za detekciju nagle promene ubrzanja (deltaA) u m/s^2
    -->
    <add key="A_threshold"       value="1.5"/>

    <!-- Prag za detekciju uticaja vetra (Weffect) u m/s -->
    <add key="W_threshold"       value="2.0"/>

    <!-- Prag za odstupanje od tekuceg proseka (±%) -->
    <add key="DeviationPercent"  value="25"/>
  </appSettings>

  <system.serviceModel>
    <services>
      <service name="Server.DroneService">
        <host>
          <baseAddresses>
            <add baseAddress="net.tcp://localhost:4100"/>
          </baseAddresses>
        </host>

        <!--
          ZADATAK 2: netTcpBinding endpoint
            - transferMode="Streamed" za streaming prenos
            - MaxReceivedMessageSize za vece poruke
            - Timeouts konfigurisani
        -->
        <endpoint address="Drone"
                  binding="netTcpBinding"
                  bindingConfiguration="droneBinding"
                  contract="Common.IDroneService">
          <identity>
            <dns value="localhost"/>
          </identity>
        </endpoint>
      </service>
    </services>

    <bindings>
      <netTcpBinding>
        <binding name="droneBinding"
                 transferMode="Streamed"
                 maxReceivedMessageSize="10485760"
                 openTimeout="00:00:10"
                 closeTimeout="00:00:10"
                 sendTimeout="00:00:30"
                 receiveTimeout="00:10:00"/>
      </netTcpBinding>
    </bindings>
  </system.serviceModel>
</configuration>
