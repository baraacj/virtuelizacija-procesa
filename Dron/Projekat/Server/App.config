<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
	<appSettings>
		<!-- Путања за чување фајлова сесије -->
		<add key="storagePath" value="DroneStorage"/>
		
		<!-- Праг за детекцију наглих промена убрзања (ΔA) у m/s² -->
		<add key="A_threshold" value="1.5"/>
		
		<!-- Праг за детекцију утицаја ветра (Weffect) у m/s -->
		<add key="W_threshold" value="2.0"/>
		
		<!-- Проценат одступања од просека за OutOfBand упозорења (±%) -->
		<add key="DeviationPercent" value="25"/>
	</appSettings>
	<system.serviceModel>
		<services>
			<service name="Server.DroneService">
				<host>
					<baseAddresses>
						<add baseAddress="net.tcp://localhost:4100"/>
					</baseAddresses>
				</host>
				<endpoint address="Drone"
						 binding="netTcpBinding"
						 bindingConfiguration="streamBinding"
						 contract="Common.IDroneService">
						<identity>
							<dns value="localhost"/>
						</identity>
				</endpoint>
			</service>
		</services>
		<bindings>
			<netTcpBinding>
				<binding name="streamBinding" transferMode="Streamed" maxReceivedMessageSize="10485760" openTimeout="00:00:10" closeTimeout="00:00:10" sendTimeout="00:00:30" receiveTimeout="00:10:00" />
			</netTcpBinding>
		</bindings>
	</system.serviceModel>
</configuration>