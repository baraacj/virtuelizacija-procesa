<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2"/>
  </startup>

  <appSettings>
    <!--
      ZADATAK 1 (e): Pragovi u konfiguraciji
      (citaju se i na klijentu za prikaz, a na serveru za analitiku)
    -->
    <add key="A_threshold"      value="1.5"/>
    <add key="W_threshold"      value="2.0"/>
    <add key="DeviationPercent" value="25"/>
  </appSettings>

  <system.serviceModel>
    <client>
      <endpoint name="Drone"
                address="net.tcp://localhost:4100/Drone"
                binding="netTcpBinding"
                bindingConfiguration="droneBinding"
                contract="Common.IDroneService"/>
    </client>
    <bindings>
      <netTcpBinding>
        <!--
          ZADATAK 2: netTcpBinding konfiguracija
            - transferMode="Streamed"
            - MaxReceivedMessageSize za vece poruke
            - Timeouts
        -->
        <binding name="droneBinding"
                 transferMode="Streamed"
                 maxReceivedMessageSize="10485760"
                 openTimeout="00:00:10"
                 closeTimeout="00:00:10"
                 sendTimeout="00:00:30"
                 receiveTimeout="00:10:00"/>
      </netTcpBinding>
    </bindings>
  </system.serviceModel>
</configuration>
